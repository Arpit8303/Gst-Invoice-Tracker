generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Invoice {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNo     String
  date          String
  businessName  String
  gstin         String
  customerName  String
  customerGstin String?
  supplyType    String
  lineItems     Json
  subtotal      Float
  cgst          Float
  sgst          Float
  igst          Float
  grandTotal    Float
  createdAt     DateTime @default(now())
}